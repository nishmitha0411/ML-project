def get_palette(undertone):
    if undertone == "Warm":
        return ["Coral", "Mustard", "Olive"]
    elif undertone == "Cool":
        return ["Royal Blue", "Lavender", "Rose"]
    else:
        return ["Soft Gray", "Ivory", "Dusty Blue"]
